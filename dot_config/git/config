# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
	name = erikjwright
	email = hey@erikwright.dev
[init]
	defaultBranch = main
[core]
	editor = nvim
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
[merge]
	tool = nvimdiff
[diff]
	tool = nvimdiff
[mergetool]
	path = nvim
[difftool]
	path = nvim
[pull]
	rebase = true
